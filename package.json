{
  "name": "bambu-filament-profiles",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bambu Studio filament profile source repository with generated .bbsflmt releases.",
  "scripts": {
    "vendor:status": "node scripts/bambu-profiles.mjs vendor:status",
    "vendor:collect": "node scripts/bambu-profiles.mjs vendor:collect",
    "vendor:diff": "node scripts/bambu-profiles.mjs vendor:diff",
    "vendor:propose": "node scripts/bambu-profiles.mjs vendor:propose",
    "vendor:ingest": "node scripts/bambu-profiles.mjs vendor:ingest",
    "vendor:lock-inputs": "node scripts/bambu-profiles.mjs vendor:lock-inputs",
    "profiles:expand-inherits": "node scripts/bambu-profiles.mjs profiles:expand-inherits",
    "reports:vendor-state": "node scripts/bambu-profiles.mjs reports:vendor-state",
    "verify": "node scripts/bambu-profiles.mjs verify",
    "build:bbsflmt": "node scripts/bambu-profiles.mjs build:bbsflmt",
    "generate:readme": "node scripts/bambu-profiles.mjs generate:readme",
    "pr:mergeability": "node scripts/check-pr-mergeability.mjs",
    "ci": "npm run verify && npm run build:bbsflmt && npm run verify"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "yaml": "^2.7.0"
  }
}
